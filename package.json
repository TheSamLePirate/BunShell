{
  "name": "bunshell",
  "version": "0.6.0",
  "description": "Typed agent shell system — TypeScript types as permissions",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "bunshell": "bin/bunshell.ts",
    "bunshell-server": "bin/bunshell-server.ts",
    "bunshell-init": "bin/bunshell-init.ts"
  },
  "scripts": {
    "shell": "bun run bin/bunshell.ts",
    "shell:audit": "bun run bin/bunshell.ts --audit",
    "server": "bun run bin/bunshell-server.ts --verbose",
    "start": "bun run bin/bunshell-server.ts",
    "dev": "bun run bin/bunshell-server.ts & bun run dashboard:dev",
    "dashboard:install": "cd dashboard && bun install",
    "dashboard:dev": "cd dashboard && bun run dev",
    "dashboard:build": "cd dashboard && bun run build",
    "build": "bun run dashboard:install && bun run dashboard:build",
    "init": "bun run bin/bunshell-init.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && bun test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.2.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@mariozechner/pi-tui": "^0.66.0",
    "chalk": "^5.6.2"
  }
}
