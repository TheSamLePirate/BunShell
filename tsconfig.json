{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@bunshell/*": ["./src/*"]
    },
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "examples/**/*.ts", "tests/**/*.ts"],
  "exclude": ["tests/agent/fixtures/**", ".typecheck-tmp/**"]
}
